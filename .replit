modules = ["nodejs-20", "web"]

# Beritahu Replit untuk langsung jalankan server
run = "npm run dev --prefix server"

# Fokus hanya pada satu pintu (8080)
[[ports]]
localPort = 8080
externalPort = 80

[workflows]
runButton = "Start Server"

[[workflows.workflow]]
name = "Start Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev --prefix server"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "webview"